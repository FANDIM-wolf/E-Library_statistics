<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ELibraryStatistics.ViewModels"
             xmlns:models="using:ELibraryStatistics.Models"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="560"
             x:Class="ELibraryStatistics.Views.AuthorSearchView"
             x:DataType="vm:AuthorSearchViewModel">

  <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto">

    <TextBlock Grid.Row="0" Text="Поиск автора" FontSize="16" FontWeight="Bold"
               Margin="0,0,0,12" />

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
      <TextBox Grid.Column="0" Watermark="Введите Фамилию Автора"
               Text="{Binding SearchText}" />
      <Button Grid.Column="1" Content="Найти" MinWidth="120" Margin="10,0,0,0"
              Command="{Binding SearchCommand}" />
      <Button Grid.Column="2" Content="Скачать CSV" MinWidth="120" Margin="10,0,0,0"
              Command="{Binding ExportCommand}" />
    </Grid>

    <Border Grid.Row="2" BorderBrush="#999" BorderThickness="1" CornerRadius="4">
      <Grid ColumnDefinitions="2*,3*">
        <DockPanel Grid.Column="0" Margin="6">
          <TextBlock DockPanel.Dock="Top" Text="Найденные авторы" FontWeight="Bold"
                     Margin="2,2,2,6" />
          <ListBox ItemsSource="{Binding Results}"
                   SelectedItem="{Binding SelectedAuthor}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:Author">
                <TextBlock>
                  <Run Text="{Binding LastName}" />
                  <Run Text="{Binding Initials}" />
                  <Run Text=" — AuthorId " Foreground="#777" />
                  <Run Text="{Binding AuthorId}" Foreground="#777" />
                </TextBlock>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>

        <Border Grid.Column="1" BorderBrush="#ddd" BorderThickness="1,0,0,0">
          <DockPanel Margin="8">
            <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedSummary}"
                       TextWrapping="Wrap" Margin="0,0,0,8" />
            <ListBox ItemsSource="{Binding Articles}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Article">
                  <TextBlock TextWrapping="Wrap">
                    <Run Text="{Binding Title}" />
                    <Run Text=" (" Foreground="#777" /><Run Text="{Binding YearPubl}"
                         Foreground="#777" /><Run Text=")" Foreground="#777" />
                  </TextBlock>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>
      </Grid>
    </Border>

    <DockPanel Grid.Row="3" Margin="0,10,0,0">
      <TextBlock DockPanel.Dock="Left" Foreground="#777">
        <Run Text="Текущая версия - " /><Run Text="{Binding Version}" />
      </TextBlock>
      <TextBlock HorizontalAlignment="Right" Foreground="#555"
                 Text="{Binding StatusMessage}" />
    </DockPanel>
  </Grid>
</UserControl>
