<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ELibraryStatistics.ViewModels"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
        x:Class="ELibraryStatistics.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="900" Height="640" MinWidth="760" MinHeight="520"
        Title="{Binding Title}">

  <DockPanel>
    <TextBlock DockPanel.Dock="Top" Margin="12,8" FontSize="18" FontWeight="Bold"
               Text="{Binding Title}" />

    <TabControl Margin="6">
      <TabItem Header="Загрузка и статистика" Content="{Binding LoadPage}" />
      <TabItem Header="Поиск автора" Content="{Binding AuthorPage}" />
      <TabItem Header="Поиск статьи" Content="{Binding ArticlePage}" />
    </TabControl>
  </DockPanel>
</Window>
